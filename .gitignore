# --- secrets: never commit ---
.env
*.pem
*.key
*credentials*

# --- python venv / caches ---
.venv/
.venv_flor/
.hf_cache/
__pycache__/
*.pyc
.ipynb_checkpoints/

# --- zero-shot: keep results/tables/reports/plots + curated key overlays only ---
outputs/zeroshot/*/overlays/
outputs/zeroshot/data/
outputs/zeroshot/exp1_grounding_dino/overlays/
!outputs/zeroshot/*/results.json
!outputs/zeroshot/comparison_table.*
!outputs/zeroshot/key_overlays/
!outputs/zeroshot/exp7_dinov2/plots/

# --- large raw imagery (kept out of git; store via DVC / external storage) ---
data/raw/
*.tif
*.tiff
mm188_*.jpg
mosaic_*.jpg
ME/

# --- heavy / regenerable outputs ---
outputs/checkpoints/
outputs/predictions/
outputs/milestone1/viewer_sources/
outputs/milestone1/debug/
outputs/milestone1/thumbnails/
# large annotated-source copies (regenerated by the viewer)
*_src.png

# keep: code, configs, reports, small masks/vectors/overlays, manifests
!outputs/milestone1/manifest.json
!outputs/milestone1/dataset_summary.json

# exp8: keep rendered maps + results + polys; drop the raw .npy score maps
outputs/zeroshot/exp8_auto/maps/

# fused pipeline: keep maps + json results + reports + config; drop raw npy caches
outputs/pipeline/priors/
outputs/pipeline/rounds/*.npy

# geoai trial: keep report + json + small overlays; drop rasters/npy caches
outputs/geoai/*.tif
outputs/geoai/*.npy
.venv_geoai/
